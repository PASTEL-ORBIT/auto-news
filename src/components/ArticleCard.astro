---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
}

const { title, description, pubDate, category, slug } = Astro.props;
const dateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="article-card">
  <div class="article-meta">
    <time datetime={pubDate.toISOString()}>{dateStr}</time>
    <CategoryBadge category={category} />
  </div>
  <h2 class="article-title">
    <a href={`${import.meta.env.BASE_URL}news/${slug}/`}>{title}</a>
  </h2>
  <p class="article-desc">{description}</p>
</article>

<style>
  .article-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .article-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }

  .article-title a {
    color: var(--color-text);
  }

  .article-title a:hover {
    color: var(--color-accent);
  }

  .article-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
