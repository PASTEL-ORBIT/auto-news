---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'テック・AI・インディーゲームの最新ニュースを毎日お届け' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="alternate" type="application/rss+xml" title="Auto News RSS" href={`${import.meta.env.BASE_URL}rss.xml`} />
  <title>{title} | Auto News</title>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href={import.meta.env.BASE_URL} class="site-title">Auto News</a>
      <nav class="site-nav">
        <a href={import.meta.env.BASE_URL}>ホーム</a>
        <a href={`${import.meta.env.BASE_URL}category/tech/`}>テック</a>
        <a href={`${import.meta.env.BASE_URL}category/ai/`}>AI</a>
        <a href={`${import.meta.env.BASE_URL}category/indie-game/`}>インディーゲーム</a>
        <a href={`${import.meta.env.BASE_URL}about/`}>About</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; PASTEL ORBIT — Powered by Claude Routines + Astro</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --color-bg: #0a0a12;
    --color-surface: rgba(255, 255, 255, 0.04);
    --color-surface-hover: rgba(255, 255, 255, 0.07);
    --color-border: rgba(255, 255, 255, 0.08);
    --color-text: #f0f0f8;
    --color-text-muted: #8888a8;
    --color-accent: #a78bfa;
    --color-accent-hover: #c4b5fd;
    --color-tech: #38bdf8;
    --color-ai: #f472b6;
    --color-indie-game: #34d399;
    --color-general: #fbbf24;
    --font-sans: 'Noto Sans JP', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --max-width: 900px;
    --glass-blur: 12px;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
    min-height: 100dvh;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 60% at 10% 20%, rgba(124, 58, 237, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 90% 80%, rgba(56, 189, 248, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(244, 114, 182, 0.06) 0%, transparent 60%);
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent-hover);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-header {
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 18, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .site-nav {
    display: flex;
    gap: 1.25rem;
    font-size: 0.85rem;
  }

  .site-nav a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .site-nav a:hover {
    color: var(--color-text);
  }

  main {
    padding: 2.5rem 0;
  }

  .site-footer {
    padding: 2rem 0;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
  }

  .glass-card {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: background 0.3s, border-color 0.3s, transform 0.2s;
  }

  .glass-card:hover {
    background: var(--color-surface-hover);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .site-header .container {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-nav {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .glass-card {
      border-radius: 12px;
      padding: 1.25rem;
    }
  }
</style>
